

<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mesai Takip</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f13;
    --surface: #18181f;
    --surface2: #21212b;
    --border: #2e2e3a;
    --text: #f0f0f5;
    --text-muted: #7a7a90;
    --green: #22d47a;
    --green-dim: #16a358;
    --yellow: #f5c542;
    --yellow-dim: #c49b20;
    --blue: #4da6ff;
    --blue-dim: #2a7fd4;
    --red: #ff5a5a;
    --red-dim: #cc3535;
    --radius: 16px;
    --radius-sm: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 16px 40px;
    position: relative;
    overflow-x: hidden;
  }

  /* Background glow */
  body::before {
    content: '';
    position: fixed;
    top: -120px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 400px;
    background: radial-gradient(ellipse, rgba(77,166,255,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    width: 100%;
    max-width: 440px;
    position: relative;
    z-index: 1;
  }

  /* HEADER */
  .header {
    text-align: center;
    margin-bottom: 32px;
    padding-top: 8px;
  }

  .header .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(77,166,255,0.12);
    border: 1px solid rgba(77,166,255,0.25);
    color: var(--blue);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 100px;
    margin-bottom: 14px;
  }

  .header .badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--blue);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .header h1 {
    font-family: 'Syne', sans-serif;
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1.1;
    color: var(--text);
  }

  .header h1 span {
    color: var(--blue);
  }

  .clock {
    margin-top: 10px;
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 300;
    letter-spacing: 0.5px;
  }

  /* CARD */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 16px;
  }

  .card-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 10px;
  }

  /* DROPDOWN */
  .select-wrapper {
    position: relative;
  }

  .select-wrapper::after {
    content: '▾';
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
    font-size: 14px;
  }

  select {
    width: 100%;
    appearance: none;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 500;
    padding: 16px 44px 16px 16px;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
  }

  select:focus {
    border-color: var(--blue);
  }

  select option {
    background: var(--surface2);
  }

  /* CURRENT STATUS */
  .status-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin-top: 14px;
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
    transition: background 0.3s;
  }

  .status-dot.green { background: var(--green); box-shadow: 0 0 8px var(--green); }
  .status-dot.yellow { background: var(--yellow); box-shadow: 0 0 8px var(--yellow); }
  .status-dot.red { background: var(--red); box-shadow: 0 0 8px var(--red); }

  .status-text {
    font-size: 13px;
    color: var(--text-muted);
  }

  .status-text strong {
    color: var(--text);
    font-weight: 500;
  }

  /* SETUP SCREEN */
  .setup-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 20px;
  }

  .setup-screen .setup-icon {
    font-size: 56px;
    margin-bottom: 4px;
  }

  .setup-screen h2 {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 700;
  }

  .setup-screen p {
    font-size: 14px;
    color: var(--text-muted);
    max-width: 260px;
    line-height: 1.5;
  }

  .name-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    font-weight: 500;
    padding: 18px 16px;
    outline: none;
    text-align: center;
    transition: border-color 0.2s;
  }

  .name-input::placeholder { color: var(--text-muted); }
  .name-input:focus { border-color: var(--blue); }

  .btn-save-name {
    width: 100%;
    background: linear-gradient(135deg, var(--blue), var(--blue-dim));
    color: #001026;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'Syne', sans-serif;
    font-size: 16px;
    font-weight: 700;
    padding: 18px;
    cursor: pointer;
    transition: filter 0.15s, transform 0.12s;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-save-name:active { transform: scale(0.97); filter: brightness(0.9); }
  .btn-save-name:hover { filter: brightness(1.08); }

  /* BUTTONS GRID */
  .buttons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 22px 16px;
    border: none;
    border-radius: var(--radius);
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease, filter 0.12s ease;
    overflow: hidden;
    min-height: 110px;
    -webkit-tap-highlight-color: transparent;
  }

  .btn .btn-icon {
    font-size: 28px;
    line-height: 1;
  }

  .btn .btn-label {
    font-size: 13px;
    letter-spacing: 0.2px;
    line-height: 1.2;
    text-align: center;
  }

  /* Ripple */
  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0;
    border-radius: inherit;
    transition: opacity 0.15s;
  }

  .btn:active::after { opacity: 0.08; }

  .btn:active {
    transform: scale(0.95);
    filter: brightness(0.9);
  }

  .btn:hover { filter: brightness(1.08); }

  /* Button colors */
  .btn-start {
    background: linear-gradient(135deg, var(--green), var(--green-dim));
    color: #001a0d;
    box-shadow: 0 4px 24px rgba(34,212,122,0.25);
  }

  .btn-break-start {
    background: linear-gradient(135deg, var(--yellow), var(--yellow-dim));
    color: #1a1200;
    box-shadow: 0 4px 24px rgba(245,197,66,0.25);
  }

  .btn-break-end {
    background: linear-gradient(135deg, var(--blue), var(--blue-dim));
    color: #001026;
    box-shadow: 0 4px 24px rgba(77,166,255,0.25);
  }

  .btn-end {
    background: linear-gradient(135deg, var(--red), var(--red-dim));
    color: #1a0000;
    box-shadow: 0 4px 24px rgba(255,90,90,0.25);
  }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.35s;
    opacity: 0;
    z-index: 999;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .toast.success { border-color: rgba(34,212,122,0.4); }
  .toast.error { border-color: rgba(255,90,90,0.4); }
  .toast.loading { border-color: rgba(77,166,255,0.4); }

  .toast-icon { font-size: 18px; }

  /* HISTORY */
  .history-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 280px;
    overflow-y: auto;
  }

  .history-list::-webkit-scrollbar { width: 4px; }
  .history-list::-webkit-scrollbar-track { background: transparent; }
  .history-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .history-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--surface2);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .history-icon { font-size: 16px; }

  .history-info { flex: 1; min-width: 0; }

  .history-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .history-action {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 1px;
  }

  .history-time {
    font-size: 11px;
    color: var(--text-muted);
    flex-shrink: 0;
    font-weight: 300;
  }

  .empty-state {
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
    padding: 20px 0;
  }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 6px 0 16px;
  }

  /* Spinner */
  .spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(77,166,255,0.3);
    border-top-color: var(--blue);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .btn-change-name {
    background: none;
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    padding: 6px 14px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    margin-top: 4px;
  }
  .btn-change-name:hover { border-color: var(--blue); color: var(--blue); }

  @media (max-width: 360px) {
    .btn { min-height: 96px; padding: 18px 12px; }
    .btn .btn-icon { font-size: 24px; }
    .btn .btn-label { font-size: 12px; }
  }
</style>
</head>
<body>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <div class="badge">Canlı Sistem</div>
    <h1>Mesai<br><span>Takip</span></h1>
    <div class="clock" id="clock">—</div>
  </div>

  <!-- SETUP SCREEN (ilk açılışta görünür) -->
  <div id="setupScreen" class="setup-screen" style="display:none;">
    <div class="setup-icon">👤</div>
    <h2>Hoş geldiniz!</h2>
    <p>Uygulamayı kullanmadan önce adınızı ve soyadınızı girin. Bu bilgi cihazınızda kaydedilir.</p>
    <input class="name-input" id="nameInput" type="text" placeholder="Ad Soyad" maxlength="50" autocomplete="name" />
    <button class="btn-save-name" onclick="saveName()">Kaydet ve Başla →</button>
  </div>

  <!-- MAIN APP (isim kaydedildikten sonra görünür) -->
  <div id="mainApp" style="display:none; width:100%;">
    <!-- ÇALIŞAN KARTI -->
    <div class="card">
      <div class="card-label">Aktif Çalışan</div>
      <div class="status-bar">
        <div class="status-dot green" id="statusDot"></div>
        <div class="status-text"><strong id="employeeDisplay">—</strong></div>
      </div>
      <div style="text-align:right; margin-top: 10px;">
        <button class="btn-change-name" onclick="changeName()">✏️ İsmi değiştir</button>
      </div>
    </div>

  <!-- ACTION BUTTONS -->
  <div class="card">
    <div class="card-label">İşlem Seçimi</div>
    <div class="divider"></div>
    <div class="buttons-grid">
      <button class="btn btn-start" onclick="sendAction('İşe Başladı', '🟢', 'green')">
        <span class="btn-icon">🟢</span>
        <span class="btn-label">İşe Başla</span>
      </button>
      <button class="btn btn-break-start" onclick="sendAction('Molaya Çıktı', '🟡', 'yellow')">
        <span class="btn-icon">🟡</span>
        <span class="btn-label">Molaya Çık</span>
      </button>
      <button class="btn btn-break-end" onclick="sendAction('Moladan Döndü', '🔵', 'blue')">
        <span class="btn-icon">🔵</span>
        <span class="btn-label">Moladan Dön</span>
      </button>
      <button class="btn btn-end" onclick="sendAction('Mesaisi Bitti', '🔴', 'red')">
        <span class="btn-icon">🔴</span>
        <span class="btn-label">Mesai Bitir</span>
      </button>
    </div>
  </div>

  <!-- HISTORY -->
  <div class="card">
    <div class="card-label">Son İşlemler</div>
    <div class="divider"></div>
    <div class="history-list" id="historyList">
      <div class="empty-state">Henüz kayıt yok</div>
    </div>
  </div>

  </div><!-- /mainApp -->

</div>

<!-- TOAST -->
<div class="toast" id="toast">
  <span class="toast-icon" id="toastIcon"></span>
  <span id="toastMsg"></span>
</div>

<script>
  const GAS_URL = 'https://script.google.com/macros/s/AKfycbwbI_X05vboWCWePFF9KqjtQG5JAtv8LrIiVWI0RVwJtPoqyggUXZ91KZGzR9KtYk1oxA/exec';

  let toastTimer = null;
  let currentEmployee = '';

  // Live clock
  function updateClock() {
    const now = new Date();
    document.getElementById('clock').textContent = now.toLocaleDateString('tr-TR', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    }) + ' — ' + now.toLocaleTimeString('tr-TR');
  }
  updateClock();
  setInterval(updateClock, 1000);

  // Init: isim kaydedilmiş mi kontrol et
  function init() {
    const saved = localStorage.getItem('employeeName');
    if (saved && saved.trim()) {
      currentEmployee = saved.trim();
      document.getElementById('employeeDisplay').textContent = currentEmployee;
      document.getElementById('setupScreen').style.display = 'none';
      document.getElementById('mainApp').style.display = 'block';
    } else {
      document.getElementById('setupScreen').style.display = 'flex';
      document.getElementById('mainApp').style.display = 'none';
    }
  }

  function saveName() {
    const val = document.getElementById('nameInput').value.trim();
    if (!val) {
      document.getElementById('nameInput').focus();
      document.getElementById('nameInput').style.borderColor = 'var(--red)';
      setTimeout(() => document.getElementById('nameInput').style.borderColor = '', 1500);
      return;
    }
    localStorage.setItem('employeeName', val);
    currentEmployee = val;
    document.getElementById('employeeDisplay').textContent = currentEmployee;
    document.getElementById('setupScreen').style.display = 'none';
    document.getElementById('mainApp').style.display = 'block';
  }

  function changeName() {
    document.getElementById('nameInput').value = currentEmployee;
    document.getElementById('setupScreen').style.display = 'flex';
    document.getElementById('mainApp').style.display = 'none';
    setTimeout(() => document.getElementById('nameInput').focus(), 100);
  }

  // Enter tuşuyla kaydet
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && document.getElementById('setupScreen').style.display !== 'none') {
      saveName();
    }
  });

  async function sendAction(action, icon, dotColor) {
    if (!currentEmployee) {
      showToast('⚠️', 'Önce isminizi girin!', 'error');
      return;
    }

    const now = new Date();
    const timestamp = now.toLocaleString('tr-TR', {
      year: 'numeric', month: '2-digit', day: '2-digit',
      hour: '2-digit', minute: '2-digit', second: '2-digit'
    });

    const dot = document.getElementById('statusDot');
    dot.className = 'status-dot ' + dotColor;

    showToast('', '', 'loading', true);

    const payload = { employee: currentEmployee, action, timestamp };

    try {
      await fetch(GAS_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      addHistory(icon, currentEmployee, action, now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' }));
      showToast('✅', `"${action}" kaydedildi!`, 'success');
    } catch (err) {
      showToast('❌', 'Bağlantı hatası! Tekrar deneyin.', 'error');
      console.error(err);
    }
  }

  function addHistory(icon, name, action, time) {
    const list = document.getElementById('historyList');
    const empty = list.querySelector('.empty-state');
    if (empty) empty.remove();

    const item = document.createElement('div');
    item.className = 'history-item';
    item.innerHTML = `
      <span class="history-icon">${icon}</span>
      <div class="history-info">
        <div class="history-name">${name}</div>
        <div class="history-action">${action}</div>
      </div>
      <div class="history-time">${time}</div>
    `;
    list.insertBefore(item, list.firstChild);
    while (list.children.length > 10) list.removeChild(list.lastChild);
  }

  function showToast(icon, msg, type, isLoading = false) {
    clearTimeout(toastTimer);
    const toast = document.getElementById('toast');
    const toastIcon = document.getElementById('toastIcon');
    const toastMsg = document.getElementById('toastMsg');
    toast.className = 'toast ' + type;
    if (isLoading) {
      toastIcon.innerHTML = '<div class="spinner"></div>';
      toastMsg.textContent = 'Gönderiliyor...';
    } else {
      toastIcon.textContent = icon;
      toastMsg.textContent = msg;
    }
    toast.classList.add('show');
    if (!isLoading) {
      toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
    }
  }

  init();
</script>
</body>
</html>
